# ── Server environment variables ──────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

NODE_ENV=development
PORT=4000

# MongoDB — use Atlas free tier for production
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# JWT — generate strong random secrets (e.g. openssl rand -hex 64)
JWT_ACCESS_SECRET=<generate-with-openssl-rand-hex-64>
JWT_REFRESH_SECRET=<generate-with-openssl-rand-hex-64>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Client URL (no trailing slash)
CLIENT_URL=http://localhost:5173
# On production: CLIENT_URL=https://soma-connect.vercel.app

# Cookie settings
COOKIE_SECURE=false          # set true in production
COOKIE_DOMAIN=               # leave blank for cross-origin (Vercel↔Render)

# Cloudinary (free tier — sign up at cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email — Brevo SMTP (free 300 emails/day — sign up at brevo.com)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SOMA Connect <no-reply@soma.rw>

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Upstash Redis (optional — for rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# HuggingFace (optional — for AI search)
HF_API_TOKEN=

# Seed script passwords (optional — random if not set)
SEED_ADMIN_PASSWORD=
SEED_BUYER_PASSWORD=
